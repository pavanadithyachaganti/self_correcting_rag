# ---- LLM provider: mock | groq | gemini ----
# mock needs no key and runs the full pipeline with placeholder answers.
LLM_PROVIDER=mock

# Groq free tier: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini free tier: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Embeddings: sentence-transformers | hash ----
# sentence-transformers = real semantic embeddings, local, free (downloads a small model once).
# hash = zero-dependency fallback for constrained environments (not semantic).
EMBEDDER=sentence-transformers
ST_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# ---- Vector store: numpy | chroma ----
VECTOR_BACKEND=numpy

# ---- Retrieval ----
TOP_K=8
RERANK_TOP_N=4
RERANKER=none            # none | cross-encoder

# ---- Self-correction thresholds ----
MAX_RETRIEVAL_ATTEMPTS=2
MAX_GENERATION_ATTEMPTS=2
RELEVANCE_THRESHOLD=0.5
FAITHFULNESS_THRESHOLD=0.7
ENABLE_WEB_FALLBACK=false
